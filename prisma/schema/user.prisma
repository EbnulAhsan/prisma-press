model user {
    id           String       @id @default(uuid())
    name         String       @db.VarChar(255)
    email        String       @unique
    password     String
    activeStatus ActiveStatus @default(Active)
    role         Role         @default(User)
    createdAt    DateTime     @default(now())
    updatedAt    DateTime     @updatedAt

    profile profile?

    comments Comment[]
    posts post[]

    @@map("users")
}
